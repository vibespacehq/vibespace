# Kubernetes binaries (downloaded by scripts, not committed to git)
# These files are large (~150MB total) and rebuilt on each platform during CI/CD

# macOS binaries
macos/colima
macos/lima
macos/limactl

# Linux binaries
linux/k3s

# kubectl (shared, platform-specific)
kubectl-darwin-amd64
kubectl-darwin-arm64
kubectl-linux-amd64
kubectl-linux-arm64

# Temporary download artifacts
*.tar.gz
*.zip
*.tmp

# Checksum files (generated during build)
*.sha256
*.md5
