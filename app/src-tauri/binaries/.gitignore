# Kubernetes binaries (downloaded by scripts, not committed to git)
# These files are large (~150MB total) and rebuilt on each platform during CI/CD

# macOS binaries
macos/colima
macos/colima-*
macos/lima
macos/limactl

# Linux binaries
linux/k3s
linux/k3s-*

# kubectl (shared, platform-specific) - all variations
kubectl-*

# mkcert (downloaded during build) - all variations
mkcert-*

# portfwd (built during build) - all variations
portfwd-darwin-*
portfwd-linux-*

# Temporary download artifacts
*.tar.gz
*.zip
*.tmp

# Checksum files (generated during build)
*.sha256
*.md5
