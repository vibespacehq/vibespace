{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vibespace",
  "version": "0.1.0",
  "identifier": "com.vibespace.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "vibespaces",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "theme": "Dark",
        "visible": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/macos/colima",
      "binaries/linux/k3s",
      "binaries/kubectl-darwin-arm64",
      "binaries/kubectl-linux-amd64"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": null,
      "entitlements": null,
      "resources": [
        "binaries/macos/lima-dist/**/*"
      ]
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
