#!/bin/bash
# vibespace Permission Hook for Claude Code (PreToolUse)
#
# This script is called by Claude Code before each tool use.
# It checks agent configuration and either auto-allows or
# POSTs to the TUI's permission server for user approval.
#
# Input (stdin): JSON from Claude with tool information
# Output (stdout): JSON with the permission decision (PreToolUse format)
#
# Environment variables:
#   VIBESPACE_SKIP_PERMISSIONS  - If "true", auto-allow all tools
#   VIBESPACE_DISALLOWED_TOOLS  - Comma-separated list of disallowed tools (auto-deny these)
#   VIBESPACE_ALLOWED_TOOLS     - Comma-separated list of allowed tools (auto-allow for direct SSH)
#   VIBESPACE_PERMISSION_TOKEN  - Auth token for TUI permission server (set by TUI only)
#   VIBESPACE_PERMISSION_PORT   - Port for permission server (default: 18080)
#   VIBESPACE_AGENT             - Agent name (e.g., "claude-1")
#   VIBESPACE_NAME              - Vibespace name

set -e

# Helper to output allow decision
allow() {
    local reason="${1:-Auto-allowed by vibespace}"
    cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "permissionDecision": "allow",
    "permissionDecisionReason": "$reason"
  }
}
EOF
    exit 0
}

# Helper to output deny decision
deny() {
    local reason="${1:-Denied by vibespace}"
    cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "permissionDecision": "deny",
    "permissionDecisionReason": "$reason"
  }
}
EOF
    exit 0
}

# Read request from stdin (Claude provides tool info as JSON)
REQUEST=$(cat)

# Extract tool name from request
# Claude sends: {"tool_name": "Bash", "tool_input": {...}}
TOOL_NAME=$(echo "$REQUEST" | jq -r '.tool_name // empty')

# Debug logging (uncomment for troubleshooting)
# echo "[vibespace-hook] $(date +%H:%M:%S) Tool: $TOOL_NAME, Skip: $VIBESPACE_SKIP_PERMISSIONS, Token: ${VIBESPACE_PERMISSION_TOKEN:+set}, Allowed: $VIBESPACE_ALLOWED_TOOLS" >> /tmp/hook.log

# Check 1: If skip_permissions is enabled, auto-allow everything
if [ "$VIBESPACE_SKIP_PERMISSIONS" = "true" ]; then
    allow "skip_permissions enabled"
fi

# Check 2: If tool is in disallowed list, deny
if [ -n "$VIBESPACE_DISALLOWED_TOOLS" ] && [ -n "$TOOL_NAME" ]; then
    if echo ",$VIBESPACE_DISALLOWED_TOOLS," | grep -qi ",$TOOL_NAME,"; then
        deny "Tool '$TOOL_NAME' is disallowed"
    fi
fi

# Check 3: If permission token is set, this is a TUI session.
# POST to the permission server for user approval.
if [ -n "$VIBESPACE_PERMISSION_TOKEN" ]; then
    PERMISSION_PORT="${VIBESPACE_PERMISSION_PORT:-18080}"
    PERMISSION_HOST="${VIBESPACE_PERMISSION_HOST:-localhost}"
    TIMEOUT="${VIBESPACE_PERMISSION_TIMEOUT:-300}"

    # Build agent key from environment
    AGENT_KEY="${VIBESPACE_AGENT:-unknown}@${VIBESPACE_NAME:-unknown}"

    # Add agent identifier to request
    REQUEST=$(echo "$REQUEST" | jq --arg agent "$AGENT_KEY" '. + {agent_key: $agent}')

    # POST to permission server (blocks until TUI responds or timeout)
    RESPONSE=$(echo "$REQUEST" | curl -s -X POST \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer ${VIBESPACE_PERMISSION_TOKEN}" \
        --data @- \
        --max-time "$TIMEOUT" \
        --connect-timeout 5 \
        "http://${PERMISSION_HOST}:${PERMISSION_PORT}/permission" 2>/dev/null) || {
        # Connection failed - default to deny for safety
        deny "Permission server unavailable"
    }

    # Parse decision from response
    DECISION=$(echo "$RESPONSE" | jq -r '.decision // "deny"')
    REASON=$(echo "$RESPONSE" | jq -r '.reason // "Controlled by vibespace"')

    # Return PreToolUse hook output format expected by Claude
    cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "permissionDecision": "$DECISION",
    "permissionDecisionReason": "$REASON"
  }
}
EOF
    exit 0
fi

# Check 4: No TUI session (direct SSH). Use allowed_tools for auto-approve.
if [ -n "$VIBESPACE_ALLOWED_TOOLS" ] && [ -n "$TOOL_NAME" ]; then
    if echo ",$VIBESPACE_ALLOWED_TOOLS," | grep -qi ",$TOOL_NAME,"; then
        allow "Tool '$TOOL_NAME' is in allowed_tools"
    fi
fi

# Default: deny (no permission server, tool not in allowed list)
deny "No permission server and tool not in allowed_tools"
