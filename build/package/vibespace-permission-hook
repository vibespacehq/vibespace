#!/bin/bash
# vibespace Permission Hook for Claude Code
#
# This script is called by Claude Code when a tool requires permission.
# It POSTs to the TUI's permission server (port-forwarded from the host)
# and blocks until the user approves or denies the request.
#
# Input (stdin): JSON from Claude with tool information
# Output (stdout): JSON with the permission decision
#
# Environment variables:
#   VIBESPACE_PERMISSION_PORT - Port for permission server (default: 18080)
#   VIBESPACE_AGENT - Agent name (e.g., "claude-1")
#   VIBESPACE_NAME - Vibespace name

set -e

PERMISSION_PORT="${VIBESPACE_PERMISSION_PORT:-18080}"
PERMISSION_HOST="${VIBESPACE_PERMISSION_HOST:-localhost}"
TIMEOUT="${VIBESPACE_PERMISSION_TIMEOUT:-300}"

# Read request from stdin (Claude provides tool info as JSON)
REQUEST=$(cat)

# Build agent key from environment
AGENT_KEY="${VIBESPACE_AGENT:-unknown}@${VIBESPACE_NAME:-unknown}"

# Add agent identifier to request
# Claude sends: {"hookEventName": "PermissionRequest", "toolName": "Bash", "toolInput": "..."}
REQUEST=$(echo "$REQUEST" | jq --arg agent "$AGENT_KEY" '. + {agent_key: $agent}')

# Debug logging (uncomment for troubleshooting)
# echo "[vibespace-hook] Agent: $AGENT_KEY" >&2
# echo "[vibespace-hook] Request: $REQUEST" >&2

# POST to permission server (blocks until TUI responds or timeout)
RESPONSE=$(echo "$REQUEST" | curl -s -X POST \
    -H "Content-Type: application/json" \
    --data @- \
    --max-time "$TIMEOUT" \
    --connect-timeout 5 \
    "http://${PERMISSION_HOST}:${PERMISSION_PORT}/permission" 2>/dev/null) || {
    # Connection failed - default to deny
    # echo "[vibespace-hook] Connection failed, defaulting to deny" >&2
    RESPONSE='{"decision":"deny"}'
}

# Parse decision from response
DECISION=$(echo "$RESPONSE" | jq -r '.decision // "deny"')

# Debug logging
# echo "[vibespace-hook] Response: $RESPONSE" >&2
# echo "[vibespace-hook] Decision: $DECISION" >&2

# Return hook output format expected by Claude
cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "PermissionRequest",
    "decision": {
      "behavior": "$DECISION"
    }
  }
}
EOF
