# Caddy configuration for vibespace internal routing
# This proxy listens on port 8080 (single Knative port) and routes to internal services
# based on the HTTP Host header.

{
    # Disable admin API (not needed in containers)
    admin off

    # Disable automatic HTTPS (Traefik handles TLS termination)
    auto_https off

    # Minimal logging (reduce overhead)
    log {
        level ERROR
    }
}

# Listen on port 8080 (the single port exposed by Knative)
:8080 {
    # Route to code-server (VS Code in browser)
    @code {
        host code.*
    }
    handle @code {
        reverse_proxy localhost:8081 {
            # Preserve original Host header
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}

            # WebSocket support (required for code-server)
            header_up Connection {>Connection}
            header_up Upgrade {>Upgrade}
        }
    }

    # Route to preview server (development server: npm run dev, pnpm dev, etc.)
    @preview {
        host preview.*
    }
    handle @preview {
        reverse_proxy localhost:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}

            # WebSocket support (required for HMR)
            header_up Connection {>Connection}
            header_up Upgrade {>Upgrade}
        }
    }

    # Route to production server (next start, static files, etc.)
    @prod {
        host prod.*
    }
    handle @prod {
        reverse_proxy localhost:3001 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Fallback: Route to code-server by default
    # This handles requests without proper Host header or direct IP access
    handle {
        reverse_proxy localhost:8081 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}

            # WebSocket support
            header_up Connection {>Connection}
            header_up Upgrade {>Upgrade}
        }
    }
}
